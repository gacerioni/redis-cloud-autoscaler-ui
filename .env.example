# =============================================================================
# Redis Cloud Autoscaler UI — configuration
#
#   cp .env.example .env   then fill in TIER 1 and run:  docker compose up -d
#
# The file has three tiers:
#   TIER 1 · REQUIRED   — you must fill these (your DB + your sizing)
#   TIER 2 · OPTIONAL   — sensible defaults; change only if you want to
#   TIER 3 · ADVANCED   — auto-derived; touch only for special scenarios
#
# Editing rules (the parser is literal):
#   * No inline comments next to a value — put comments on their own line.
#       BAD:  REDIS_PASSWORD=hunter2   # my password   ← the comment becomes part of the value
#       GOOD: REDIS_PASSWORD=hunter2
#   * No quotes around values.   * Save with LF line endings, not CRLF.
# =============================================================================


# #############################################################################
# TIER 1 · REQUIRED — fill every value below
# #############################################################################

# --- Your database (from the Redis Cloud console → your DB) -------------------
# Private endpoint, host:port. Configuration tab → "Public/Private endpoint".
REDIS_HOST_AND_PORT=
# Default-user password. Security tab.
REDIS_PASSWORD=

# --- Your Redis Cloud REST API keys -------------------------------------------
# Console → Access Management → API Keys. You need TWO keys:
#   ACCOUNT_KEY = the account-wide "Account key" (public)   → header x-api-key
#   API_KEY     = your personal "User key" (secret)         → header x-api-secret-key
# The User key's owner must have the **Owner** account role — Viewer/Logs Viewer
# are read-only and the autoscaler won't be able to scale. See README.
REDIS_CLOUD_ACCOUNT_KEY=
REDIS_CLOUD_API_KEY=

# --- Which subscription + database (numeric IDs from the console URL) ---------
REDIS_CLOUD_SUBSCRIPTION_ID=
REDIS_CLOUD_DATABASE_ID=

# --- Sizing — match these to YOUR database's current numbers ------------------
# BASELINE_OPS: the throughput your DB is configured for today (console).
#   If this doesn't match, the alert fires at the wrong level.
BASELINE_OPS=25000
# BASELINE_MEM_GB: your DATASET size in GB (console). NOT the memory limit —
#   with HA the API reports memoryLimitInGb = 2× this. The UI handles the ×2.
BASELINE_MEM_GB=2.5
# BURST_OPS: the throughput a scale-up jumps to. THIS IS COST — choose the
#   capacity you're willing to pay for during a spike.
BURST_OPS=40000
# THROUGHPUT_CEILING: hard cap; the autoscaler never scales beyond this.
THROUGHPUT_CEILING=40000


# #############################################################################
# TIER 2 · OPTIONAL — defaults are fine for most runs
# #############################################################################

# --- Branding (shown in the UI header) ----------------------------------------
DEMO_CLIENT_NAME=Demo
DEMO_TAGLINE=Redis Cloud elasticity in action

# --- UI access (Basic Auth) ---------------------------------------------------
# Leave UI_AUTH_PASSWORD empty for open access. Set any value to require login
# before the UI (and its admin buttons) can be used. Strongly recommended if
# the UI is reachable from outside your network.
UI_AUTH_USERNAME=admin
UI_AUTH_PASSWORD=

# --- Scheduled scale-down (OFF by default — production-safe) -------------------
# The automatic scale-down is a DEMO convenience that returns the DB to
# baseline a few minutes after a scale-up. In production leave it OFF: the
# autoscaler reacts to REAL traffic, so this timer would pull the DB back to
# baseline mid-event and fight the autoscaler (yo-yo). Default OFF = the DB
# holds its scaled capacity until you reset manually (UI "Reset now").
#   AUTO_RESET_ENABLED=true   → opt in to auto scale-down (handy for repeatable
#                               demos), AUTO_RESET_SECONDS after a scale-up.
#   AUTO_RESET_SECONDS        → wait before the scheduled reset (only if enabled).
AUTO_RESET_ENABLED=false
AUTO_RESET_SECONDS=300

# --- Memory scaling (OFF by default — scaling RAM has direct cost) ------------
# When false, the autoscaler only acts on throughput; memory is shown as
# context only and is never changed.
MEMORY_SCALING_ENABLED=false

# --- When to scale (thresholds) -----------------------------------------------
# Throughput alert fires when live ops/sec exceed THROUGHPUT_THRESHOLD_PCT% of
# BASELINE_OPS for THROUGHPUT_THRESHOLD_FOR (debounce).
THROUGHPUT_THRESHOLD_PCT=80
THROUGHPUT_THRESHOLD_FOR=30s
# Memory thresholds — only used if MEMORY_SCALING_ENABLED=true.
MEMORY_THRESHOLD_PCT=80
MEMORY_THRESHOLD_FOR=30s
MEMORY_STEP_GB=2
MEMORY_CEILING_GB=5


# #############################################################################
# TIER 3 · ADVANCED — leave blank/default. Override only for special scenarios.
#
# The metrics HOST is discovered automatically from the subscription (the same
# creds you already gave) and the port defaults to 8070 — you do NOT need to
# set either. These knobs exist so you can override if you change cloud, region,
# private-link endpoint, metrics port, or REST API version.
# #############################################################################

# Metrics scrape host (hostname only, no port). Empty = auto-discovered from
# the subscription's prometheusEndpoint. Override only if the API-returned
# hostname isn't the one reachable over your PSC/VPC-peering link.
REDIS_CLOUD_INTERNAL_ENDPOINT=
# Port for the native Redis Cloud Prometheus metrics. Default 8070.
# REDIS_CLOUD_METRICS_PORT=8070

# REST API base URL. The API VERSION lives here (…/v1). To target a different
# version or a sovereign/dedicated endpoint, change the whole value.
# REDIS_CLOUD_API_BASE=https://api.redislabs.com/v1

# UI image + published port.
# UI_IMAGE=gacerioni/redis-cloud-autoscaler-ui:latest
# UI_PORT=8000

# Public deployment with HTTPS (only used by docker-compose.public.yml).
# DEMO_DOMAIN=
# DEMO_EMAIL=

# Internal service URLs (compose network). Only change if you re-wire services.
# PROMETHEUS_URL=http://prometheus:9090
# AUTOSCALER_URL=http://autoscaler:8080
# ALERTMANAGER_URL=http://alertmanager:9093

# These three are only published when you opt-in via docker-compose.expose.yml:
# AUTOSCALER_PORT=8080
# PROMETHEUS_PORT=9090
# ALERTMANAGER_PORT=9093
