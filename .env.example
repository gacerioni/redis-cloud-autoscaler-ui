# =============================================================================
# Redis Cloud Autoscaler UI — configuration
#
# Copy to `.env`, fill in the values below, then run:
#     docker compose up -d
#
# Variables fall into 5 groups:
#   1. Customer DB connectivity      (the database that will be scaled)
#   2. Redis Cloud REST API          (used by the autoscaler to apply scale ops)
#   3. Branding                      (cosmetic; per-customer)
#   4. Scaling policy                (WHEN to scale and HOW MUCH)
#   5. Optional public deployment    (Caddy + Let's Encrypt)
# =============================================================================

# --- 1. Customer DB connectivity ---------------------------------------------
# Private endpoint of the database to monitor / scale.
# Example: redis-12345.internal.cXXXXX.us-east1-mz.gcp.cloud.rlrcp.com:12345
REDIS_HOST_AND_PORT=

# Default-user password for the DB above.
REDIS_PASSWORD=

# Hostname-only of the cluster's internal Prometheus endpoint (no port).
# Prometheus appends :8070 to scrape the native Redis Cloud metrics endpoint.
# Example: internal.cXXXXX.us-east1-mz.gcp.cloud.rlrcp.com
#
# OPTIONAL: leave empty and the UI will auto-discover this value from the
# subscription's `prometheusEndpoint` field via the REST API at boot.
REDIS_CLOUD_INTERNAL_ENDPOINT=

# --- 2. Redis Cloud REST API -------------------------------------------------
# Create both keys in: console → Access Management → API Keys
# - Account Key  → sent as HTTP header `x-api-key`
# - User Key     → sent as HTTP header `x-api-secret-key`
REDIS_CLOUD_API_KEY=                   # User / secret key
REDIS_CLOUD_ACCOUNT_KEY=               # Account / public key

# Numeric subscription ID (visible in the console URL).
REDIS_CLOUD_SUBSCRIPTION_ID=

# Numeric database ID inside that subscription.
DEMO_DB_ID=

# --- 3. Branding -------------------------------------------------------------
DEMO_CLIENT_NAME=Demo
DEMO_TAGLINE=Redis Cloud elasticity in action

# --- 3a. UI Basic Auth (optional) --------------------------------------------
# Soft protection so anyone landing on the URL can't immediately hit /api/admin/*.
# Leave UI_AUTH_PASSWORD empty to disable. Browser prompts on first request.
UI_AUTH_USERNAME=admin
UI_AUTH_PASSWORD=                       # e.g. secret42 — empty = no auth

# --- 3b. Feature flags -------------------------------------------------------
# Memory autoscaling has direct cost impact. Default: OFF.
# When false, the IncreaseMemory rule is NEITHER registered with the
# autoscaler NOR emitted by Prometheus — Memory just shows as context info.
MEMORY_SCALING_ENABLED=false

# --- 4. Scaling policy -------------------------------------------------------
# WHEN to scale UP (a webhook fires when these thresholds are crossed)
THROUGHPUT_THRESHOLD_PCT=80            # % of BASELINE_OPS
THROUGHPUT_THRESHOLD_FOR=30s           # how long must stay above (debounce)
MEMORY_THRESHOLD_PCT=80                # % of memory limit
MEMORY_THRESHOLD_FOR=30s

# Current baselines configured on the DB (should match the Redis Cloud console).
# IMPORTANT: BASELINE_MEM_GB is the *dataset size* as shown in the console,
# NOT the memory_limit returned by the REST API. With HA enabled, the REST
# API's memoryLimitInGb is 2× the dataset size (one copy for master, one for
# replica). The UI handles this automatically and displays both values.
BASELINE_OPS=25000
BASELINE_MEM_GB=2.5

# How much to scale UP each time the threshold is crossed.
# Defaults below cap throughput at 40k ops/sec — chosen to cover the
# real-world BBB peak (~33k) with headroom, without runaway scale.
BURST_OPS=40000                        # IncreaseThroughput → jumps to this value
THROUGHPUT_CEILING=40000               # hard cap — never scale beyond this
MEMORY_STEP_GB=2                       # only used if MEMORY_SCALING_ENABLED=true
MEMORY_CEILING_GB=5                    # only used if MEMORY_SCALING_ENABLED=true

# How long to wait before the scheduled scale-down (back to baseline).
# In production this is typically hours; the short value here makes the
# demo reproducible. The UI displays a banner explaining the tradeoff.
AUTO_RESET_SECONDS=300                 # = 5 minutes

# --- 5. Optional public deployment (Caddy + Let's Encrypt) -------------------
# Only used by docker-compose.public.yml
DEMO_DOMAIN=                           # fully-qualified domain (A/AAAA → this host)
DEMO_EMAIL=                            # contact email for Let's Encrypt

# --- Power-user overrides (rarely needed) ------------------------------------
# UI_IMAGE=gacerioni/redis-cloud-autoscaler-ui:latest
# UI_PORT=8000
# These three are only used when you opt-in via docker-compose.expose.yml:
# AUTOSCALER_PORT=8080
# PROMETHEUS_PORT=9090
# ALERTMANAGER_PORT=9093
